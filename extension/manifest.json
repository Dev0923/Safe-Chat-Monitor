{
  "manifest_version": 3,
  "name": "Safety Monitor",
  "version": "1.0",
  "description": "Transparently monitors browsing activity for parent dashboard safety.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Safety Monitor Settings"
  }
}
